{
  "name": "job-tracker",
  "projectType": "application",
  "sourceRoot": "packages/job-tracker/src",
  "targets": {
    "typecheck": {
      "command": "tsc --noEmit",
      "options": {
        "cwd": "packages/job-tracker"
      }
    },
    "dev": {
      "command": "vite dev",
      "options": {
        "cwd": "packages/job-tracker"
      }
    },
    "build": {
      "command": "vite build",
      "options": {
        "cwd": "packages/job-tracker"
      }
    },
    "start": {
      "command": "node .output/server/index.mjs",
      "options": {
        "cwd": "packages/job-tracker"
      },
      "dependsOn": ["build"]
    }
  }
}
